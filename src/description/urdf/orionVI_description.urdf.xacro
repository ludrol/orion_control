          name="SwerveDrivePlugin">

    <steering_joint>left_front_turntable_joint</steering_joint>
    <steering_joint>right_front_turntable_joint</steering_joint>
    <steering_joint>left_rear_turntable_joint</steering_joint>
    <steering_joint>right_rear_turntable_joint</steering_joint>

